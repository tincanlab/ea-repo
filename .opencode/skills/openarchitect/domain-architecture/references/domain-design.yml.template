          path: ""
          description: ""
          request_schema: ""
          response_schema: ""
          error_codes: []
          auth: ""
          rate_limit: ""
      pagination: ""  # cursor | offset | none
      versioning: ""  # path | header | query

# --- TMF alignment summary ---
tmf_alignment:
