    title: ""
    status: "proposed"
    context: ""
    decision: ""
    consequences: ""
    sa_deviation: false  # true if this deviates from SA-level patterns
    sa_review_required: false

# --- Conformance report ---
sa_conformance:
  nfr_budget_fit: true  # do domain SLOs fit SA allocation?
  interface_conformance: []  # [{interface_id, status: conformant|deviated, notes}]
  pattern_conformance: []  # [{pattern, status, notes}]
  issues: []
