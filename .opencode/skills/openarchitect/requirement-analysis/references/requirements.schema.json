{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenArchitect Requirements Baseline",
  "type": "object",
  "required": ["version", "scope", "requirements", "open_questions"],
  "properties": {
    "version": { "type": "string" },
    "analysis_mode": {
      "type": "string",
      "enum": ["strict", "balanced", "deep"]
    },
    "clarification_policy": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["strict", "balanced", "deep"]
        },
        "max_questions_total": {
          "type": "integer",
          "minimum": 5,
          "maximum": 20
        },
        "max_new_questions_per_turn": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        }
      },
      "additionalProperties": true
    },
    "expansion_focus_areas": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "scope",
          "nfr",
          "integrations",
          "compliance",
          "data",
          "ux",
          "none"
        ]
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "intake_summary": { "type": "string" },
        "links": { "type": "array", "items": { "type": "string" } },
        "cascade_readiness": {
          "type": "string",
          "enum": ["ready_for_advancement_review", "not_ready_for_advancement"]
        }
      },
      "additionalProperties": true
    },
    "governance_signal": {
      "$ref": "../../common/references/schemas/governance-signal.schema.json"
    },
    "problem_statement": { "type": "string" },
    "goals": { "type": "array", "items": { "type": "string" } },
    "non_goals": { "type": "array", "items": { "type": "string" } },
    "scope": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "nfrs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "text": { "type": "string" },
          "target": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "text", "type", "priority", "status", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string", "pattern": "^req-[a-z0-9-]+$" },
          "title": { "type": "string" },
          "text": { "type": "string" },
          "type": { "type": "string", "enum": ["functional", "non_functional", "constraint"] },
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "status": { "type": "string", "enum": ["draft", "approved", "deferred"] },
          "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "open_questions": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "question", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^q-[0-9]{3}$" },
          "question": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "answered"] },
          "answer": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
