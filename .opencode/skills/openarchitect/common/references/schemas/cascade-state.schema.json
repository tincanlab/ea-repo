{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openarchitect.dev/schemas/cascade-state.schema.json",
  "title": "OpenArchitect Cascade State Artifact",
  "type": "object",
  "required": ["layers"],
  "properties": {
    "version": {
      "type": "string"
    },
    "layers": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9_]*$": {
          "type": "object",
          "required": ["status", "artifact_refs"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["not_started", "in_progress", "approved", "blocked", "rejected"]
            },
            "approved_by": {
              "type": "string"
            },
            "approved_at": {
              "type": "string"
            },
            "artifact_refs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
