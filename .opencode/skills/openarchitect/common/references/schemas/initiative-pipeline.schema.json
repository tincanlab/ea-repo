{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openarchitect.dev/schemas/initiative-pipeline.schema.json",
  "title": "Initiative Pipeline",
  "description": "Portfolio source artifact owned by PM/business/IT for routing selector generation.",
  "type": "object",
  "required": [
    "initiatives"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "portfolio_cycle": {
      "type": "string",
      "minLength": 1
    },
    "initiatives": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "initiative_id",
          "name",
          "stage",
          "description",
          "objectives"
        ],
        "properties": {
          "initiative_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "stage": {
            "type": "string",
            "enum": [
              "intake",
              "discovery",
              "sizing",
              "business_case",
              "prioritization",
              "approved_for_delivery",
              "in_delivery",
              "completed",
              "cancelled"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "objectives": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "business_case_id": {
            "type": "string"
          },
          "business_sponsor": {
            "type": "string"
          },
          "pm_owner": {
            "type": "string"
          },
          "it_owner": {
            "type": "string"
          },
          "t_shirt_size": {
            "type": "string",
            "enum": [
              "xs",
              "s",
              "m",
              "l",
              "xl"
            ]
          },
          "roi_band": {
            "type": "string",
            "enum": [
              "very_high",
              "high",
              "medium",
              "low",
              "unknown"
            ]
          },
          "solution_repo_url": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "approved",
              "ready",
              "in_progress",
              "planned",
              "paused",
              "completed",
              "cancelled",
              "archived"
            ]
          },
          "routing": {
            "type": "object",
            "properties": {
              "publish_to_selector": {
                "type": "boolean"
              },
              "selector_status": {
                "type": "string",
                "enum": [
                  "active",
                  "approved",
                  "ready",
                  "in_progress",
                  "planned",
                  "paused",
                  "completed",
                  "cancelled",
                  "archived"
                ]
              }
            },
            "additionalProperties": true
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "routing": {
                  "properties": {
                    "publish_to_selector": {
                      "const": true
                    }
                  },
                  "required": [
                    "publish_to_selector"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "solution_repo_url",
                "routing"
              ],
              "properties": {
                "routing": {
                  "required": [
                    "selector_status"
                  ]
                }
              }
            }
          }
        ],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
