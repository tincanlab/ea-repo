{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openarchitect.dev/schemas/domain-engagements.schema.json",
  "title": "SA Domain Engagements Catalog",
  "description": "Selector catalog for routing domain architect containers by engagement_id from the SA repo.",
  "type": "object",
  "required": [
    "engagements"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "engagements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "engagement_id",
          "initiative_id",
          "domain_id",
          "domain_repo_url",
          "status"
        ],
        "properties": {
          "engagement_id": {
            "type": "string",
            "minLength": 1
          },
          "engagement_uuid": {
            "type": "string",
            "format": "uuid",
            "description": "Optional immutable identity. Not used for selector routing."
          },
          "initiative_id": {
            "type": "string",
            "minLength": 1
          },
          "domain_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "domain_repo_url": {
            "type": "string",
            "minLength": 1
          },
          "tmfc_component_id": {
            "type": "string",
            "minLength": 1
          },
          "handoff_ref": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "approved",
              "ready",
              "in_progress",
              "planned",
              "paused",
              "completed",
              "cancelled",
              "archived"
            ]
          },
          "owner": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
