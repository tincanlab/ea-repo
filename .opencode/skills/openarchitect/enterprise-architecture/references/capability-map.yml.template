        description: ""
        strategic_priority: "medium"
        current_maturity: "initial"
        target_maturity: "managed"
        owning_domain: ""
        key_applications: []  # from portfolio if available
        gaps: []
        investment_required: ""  # tshirt: S/M/L/XL

# --- Heatmap summary ---
heatmap:
  critical_gaps: []  # cap-IDs where current << target and priority = critical/high
