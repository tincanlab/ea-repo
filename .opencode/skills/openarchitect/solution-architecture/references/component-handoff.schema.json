{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openarchitect.dev/schemas/component-handoff.schema.json",
  "title": "OpenArchitect SA Component Handoff Artifact",
  "type": "object",
  "required": ["version", "domain", "components"],
  "properties": {
    "version": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "source_layer": {
      "type": "string",
      "const": "solution_architecture"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "provided_interfaces", "consumed_interfaces"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^comp-[a-z0-9][a-z0-9-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "provided_interfaces": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^ifc-[a-z0-9][a-z0-9-]*$"
            }
          },
          "consumed_interfaces": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^ifc-[a-z0-9][a-z0-9-]*$"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["component_id", "interface_id", "required_before"],
              "properties": {
                "component_id": {
                  "type": "string",
                  "pattern": "^comp-[a-z0-9][a-z0-9-]*$"
                },
                "interface_id": {
                  "type": "string",
                  "pattern": "^ifc-[a-z0-9][a-z0-9-]*$"
                },
                "required_before": {
                  "type": "string",
                  "enum": ["design", "implementation", "deployment"]
                }
              },
              "additionalProperties": true
            }
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
